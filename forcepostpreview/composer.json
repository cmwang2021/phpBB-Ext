{
    "name": "ecyaz/forcepostpreview",
    "type": "phpbb-extension",
    "description": "Requires users to preview a post before the Submit button becomes available.",
    "homepage": "https://github.com/ECYaz/phpBB-Extensions",
    "version": "1.0.0",
    "license": "GPL-2.0-only",
    "authors": [
        { "name": "ECYaz" }
    ],
    "require": {
        "php": ">=7.2"
    },
    "extra": {
        "display-name": "Force Post Preview",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0@dev"
        }
    }
}
